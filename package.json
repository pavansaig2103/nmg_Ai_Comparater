{
  "name": "ai-competitor-comparison-brief-generator",
  "version": "1.0.0",
  "description": "Complete AI SaaS comparison brief generator for Nethi Mallikarjun Gupta.",
  "scripts": {
    "install-all": "npm install",
    "dev-backend": "node backend/index.js",
    "dev-frontend": "vite frontend",
    "dev": "node free-ports.js && concurrently \"npm run dev-backend\" \"npm run dev-frontend\"",
    "start-backend": "node backend/index.js",
    "start-frontend": "npm run build && vite preview frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "prisma generate --schema backend/prisma/schema.prisma",
    "build:frontend": "vite build frontend",
    "vercel-build": "npm run build",
    "db:push": "prisma db push --schema backend/prisma/schema.prisma",
    "db:seed": "prisma db seed --schema backend/prisma/schema.prisma",
    "lint": "eslint -c frontend/eslint.config.mjs frontend"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.20.0",
    "morgan": "^1.10.0",
    "openai": "^6.43.0",
    "pg": "^8.11.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  },
  "prisma": {
    "seed": "node backend/prisma/seed.js"
  }
}
